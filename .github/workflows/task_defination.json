{
    "family": "multi-doc-chatstd",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::635026339910:role/ecsTaskExecutionRole",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "1024",
    "memory": "8192",
    "containerDefinitions": [
      {
        "name": "multi-doc-chat-live-container",
        "image": "635026339910.dkr.ecr.us-east-1.amazonaws.com/multi-doc-chat-repo",
        "cpu": 1024,
        "essential": true,
        "portMappings": [
          {
            "containerPort": 8080,
            "hostPort": 8080,
            "protocol": "tcp",
            "name": "multi-doc-chat-live-container-8080-tcp",
            "appProtocol": "http"
          }
        ],
        "environment": [
          {
            "name": "ENV",
            "value": "production"
          }
        ],
        "secrets": [
          {
            "name": "apikeytest",
            "valueFrom": "arn:aws:secretsmanager:us-east-1:635026339910:secret:apikeytest-O0073l"
          }
  
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/multi-doc-chatstd",
            "awslogs-region": "us-east-1",
            "awslogs-stream-prefix": "ecs",
            "awslogs-create-group": "true"
          }
        }
      }
    ]
  }
  